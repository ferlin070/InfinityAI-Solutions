# Environment Configuration (development / production)
ENVIRONMENT=production

# Admin Credentials (mandatory in production)
ADMIN_EMAIL=bos@infinityai.com
ADMIN_PASSWORD=your_strong_password_here

# Signs session tokens (backend/src/core/sessions.py). Without this, sessions
# are signed with a key derived from ADMIN_PASSWORD instead — set a real
# random value in production (e.g. `openssl rand -hex 32`).
SESSION_SECRET_KEY=change_this_to_a_long_random_secret

# NVIDIA NIM API Configuration
NVIDIA_NIM_API_KEY=your_nvidia_api_key_here

# OpenAI API Configuration (AI execution layer / CrewAI — MVP's only provider)
OPENAI_API_KEY=your_openai_api_key_here

# Google Apps Script Web App URL (for Drive uploads)
GAS_WEB_APP_URL=https://script.google.com/macros/d/.../usercontent

# Google Drive Folder IDs (one per agent)
ZARA_DRIVE_FOLDER_ID=folder_id_for_zara
DANISH_DRIVE_FOLDER_ID=folder_id_for_danish
MAYA_DRIVE_FOLDER_ID=folder_id_for_maya
AMELIA_DRIVE_FOLDER_ID=folder_id_for_amelia
AIMAN_DRIVE_FOLDER_ID=folder_id_for_aiman
ADILA_DRIVE_FOLDER_ID=folder_id_for_adila
HAKIM_DRIVE_FOLDER_ID=folder_id_for_hakim

# Server Port (default: 7860 for Hugging Face Spaces)
PORT=7860

# Supabase (M0 — lihat docs/deployment.md §5)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# WhatsApp Gateway (whatsapp-web.js session manager — lihat gateway/ dan
# docs/deployment.md §7). WAJIB kalau nak guna ciri Operasi WhatsApp — tanpa
# ini /api/channels dan lain-lain endpoint WA akan gagal connect ke gateway.
# Set BOTH backend dan gateway kepada NILAI SAMA — ini "kata laluan" antara
# dua servis, bukan default docker-compose sahaja.
GATEWAY_SHARED_SECRET=change_this_to_a_long_random_secret
# Backend -> Gateway: docker-compose guna hostname dalaman (http://gateway-wa:3000).
# Di Railway/Render, tukar kepada URL awam servis gateway anda, cth:
# https://your-gateway-production.up.railway.app
GATEWAY_INTERNAL_URL=http://gateway-wa:3000
# Gateway -> Backend (hantar mesej masuk balik ke webhook). docker-compose guna
# hostname dalaman; di Railway/Render tukar kepada URL awam servis backend anda,
# cth: https://your-backend-production.up.railway.app/webhooks/wa-gateway
FASTAPI_WEBHOOK_URL=http://backend:7860/webhooks/wa-gateway

