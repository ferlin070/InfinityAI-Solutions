# Environment Configuration (development / production)
ENVIRONMENT=production

# Admin Credentials (mandatory in production)
ADMIN_EMAIL=bos@infinityai.com
ADMIN_PASSWORD=your_strong_password_here

# NVIDIA NIM API Configuration
NVIDIA_NIM_API_KEY=your_nvidia_api_key_here

# OpenAI API Configuration (AI execution layer / CrewAI — MVP's only provider)
OPENAI_API_KEY=your_openai_api_key_here

# Google Apps Script Web App URL (for Drive uploads)
GAS_WEB_APP_URL=https://script.google.com/macros/d/.../usercontent

# Google Drive Folder IDs (one per agent)
ZARA_DRIVE_FOLDER_ID=folder_id_for_zara
DANISH_DRIVE_FOLDER_ID=folder_id_for_danish
MAYA_DRIVE_FOLDER_ID=folder_id_for_maya
AMELIA_DRIVE_FOLDER_ID=folder_id_for_amelia
AIMAN_DRIVE_FOLDER_ID=folder_id_for_aiman
ADILA_DRIVE_FOLDER_ID=folder_id_for_adila
HAKIM_DRIVE_FOLDER_ID=folder_id_for_hakim

# Server Port (default: 7860 for Hugging Face Spaces)
PORT=7860

# Supabase (M0 — lihat docs/deployment.md §5)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

