# Environment Configuration (development / production)
ENVIRONMENT=production

# Admin Credentials (mandatory in production)
ADMIN_EMAIL=bos@infinityai.com
ADMIN_PASSWORD=your_strong_password_here

# NVIDIA NIM API Configuration
NVIDIA_NIM_API_KEY=your_nvidia_api_key_here

# OpenAI API Configuration (AI execution layer / CrewAI — MVP's only provider)
OPENAI_API_KEY=your_openai_api_key_here

# ─── Optional AI provider bridges (leave blank to disable) ──────────────────
# Set these if you want the corresponding provider to be available in
# `agents.provider` in the DB / config_store. Missing keys = provider rejected
# at runtime with a clear error.

# Anthropic (Claude)
ANTHROPIC_API_KEY=

# Google Gemini (either name works)
GEMINI_API_KEY=
GOOGLE_API_KEY=

# OpenRouter (multi-model proxy)
OPENROUTER_API_KEY=

# Ollama (local). OLLAMA_BASE_URL defaults to http://localhost:11434/v1.
OLLAMA_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434/v1

# Azure OpenAI
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_BASE_URL=

# Google Apps Script Web App URL (for Drive uploads)
GAS_WEB_APP_URL=https://script.google.com/macros/d/.../usercontent

# Google Drive Folder IDs (one per agent)
ZARA_DRIVE_FOLDER_ID=folder_id_for_zara
DANISH_DRIVE_FOLDER_ID=folder_id_for_danish
MAYA_DRIVE_FOLDER_ID=folder_id_for_maya
AMELIA_DRIVE_FOLDER_ID=folder_id_for_amelia
AIMAN_DRIVE_FOLDER_ID=folder_id_for_aiman
ADILA_DRIVE_FOLDER_ID=folder_id_for_adila
HAKIM_DRIVE_FOLDER_ID=folder_id_for_hakim

# Server Port (default: 7860 for Hugging Face Spaces)
PORT=7860

# Supabase (M0 — lihat docs/deployment.md §5)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ─── Playwright / browser (optional) ─────────────────────────────────────────
# Headless Chromium is launched on demand by browser tools. Set
# BROWSER_HEADLESS=false to see the browser (local dev). Provide extra Chromium
# flags via BROWSER_LAUNCH_ARGS. After install: `playwright install chromium`.
BROWSER_HEADLESS=true
BROWSER_LAUNCH_ARGS=
BROWSER_IDLE_TTL_SECONDS=300
BROWSER_DEFAULT_TIMEOUT_MS=15000
BROWSER_SCREENSHOT_DIR=/tmp/infinityai_screenshots
BROWSER_SESSION_ID=

# ─── MCP servers (optional) ──────────────────────────────────────────────────
# JSON array of server configs. Example:
# MCP_SERVERS=[{"name":"filesystem","transport":"stdio","command":["uvx","mcp-server-filesystem","/data"]},{"name":"remote","transport":"http","url":"https://example.com/mcp","headers":{"Authorization":"Bearer xyz"}}]
MCP_SERVERS=
